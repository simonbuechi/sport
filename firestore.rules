rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read exercises, but only the admin can modify them
    match /exercises/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'Ib3y7vFU94QZbgbXB7flrrHGbtk1';
    }
    
    // Allow users to read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Workout activities are private to the user
      match /activities/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /templates/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
